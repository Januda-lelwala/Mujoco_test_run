<mujoco model="simple_human">
  <compiler angle="radian"/>

  <option timestep="0.002" gravity="0 0 -9.81"/>

  <default>
    <joint limited="true" damping="1.0" stiffness="5.0"/>
    <geom contype="1" conaffinity="1" condim="3" friction="1 0.05 0.05" rgba="0.8 0.6 0.4 1"/>
  </default>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" type="plane" size="10 10 0.1" rgba="0.5 0.5 0.5 1" contype="1" conaffinity="1"/>

    <!-- Torso (root body) -->
    <body name="torso" pos="0 0 1.2">
      <freejoint name="root"/>
      <geom name="torso_geom" type="capsule" fromto="0 0 -0.15 0 0 0.15" size="0.12" rgba="0.8 0.6 0.4 1"/>

      <!-- Head -->
      <body name="head" pos="0 0 0.28">
        <joint name="neck" type="hinge" axis="0 1 0" range="-0.5 0.5" damping="2" stiffness="10"/>
        <geom name="head_geom" type="sphere" size="0.1" rgba="0.8 0.6 0.4 1"/>
      </body>

      <!-- Left Upper Arm -->
      <body name="left_upper_arm" pos="0.22 0 0.1">
        <joint name="left_shoulder" type="ball" damping="2.0"/>
        <geom name="luarm_geom" type="capsule" fromto="0 0 0 0.0 0 -0.22" size="0.05" rgba="0.8 0.6 0.4 1"/>

        <!-- Left Lower Arm -->
        <body name="left_lower_arm" pos="0 0 -0.22">
          <joint name="left_elbow" type="hinge" axis="0 1 0" range="-1.8 0.05" damping="1"/>
          <geom name="llarm_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.04" rgba="0.8 0.6 0.4 1"/>

          <!-- Left Hand -->
          <body name="left_hand" pos="0 0 -0.2">
            <geom name="lhand_geom" type="sphere" size="0.04" rgba="0.8 0.6 0.4 1"/>
          </body>
        </body>
      </body>

      <!-- Right Upper Arm -->
      <body name="right_upper_arm" pos="-0.22 0 0.1">
        <joint name="right_shoulder" type="ball" damping="2.0"/>
        <geom name="ruarm_geom" type="capsule" fromto="0 0 0 0 0 -0.22" size="0.05" rgba="0.8 0.6 0.4 1"/>

        <!-- Right Lower Arm -->
        <body name="right_lower_arm" pos="0 0 -0.22">
          <joint name="right_elbow" type="hinge" axis="0 1 0" range="-1.8 0.05" damping="1"/>
          <geom name="rlarm_geom" type="capsule" fromto="0 0 0 0 0 -0.2" size="0.04" rgba="0.8 0.6 0.4 1"/>

          <!-- Right Hand -->
          <body name="right_hand" pos="0 0 -0.2">
            <geom name="rhand_geom" type="sphere" size="0.04" rgba="0.8 0.6 0.4 1"/>
          </body>
        </body>
      </body>

      <!-- Pelvis -->
      <body name="pelvis" pos="0 0 -0.2">
        <joint name="lower_back" type="ball" damping="4.0"/>
        <geom name="pelvis_geom" type="capsule" fromto="0 0 -0.05 0 0 0.05" size="0.10" rgba="0.8 0.6 0.4 1"/>

        <!-- Left Upper Leg -->
        <body name="left_upper_leg" pos="0.1 0 -0.1">
          <joint name="left_hip" type="ball" damping="3.0"/>
          <geom name="luleg_geom" type="capsule" fromto="0 0 0 0 0 -0.28" size="0.07" rgba="0.8 0.6 0.4 1"/>

          <!-- Left Lower Leg -->
          <body name="left_lower_leg" pos="0 0 -0.28">
            <joint name="left_knee" type="hinge" axis="0 1 0" range="-1.8 0.05" damping="1.5"/>
            <geom name="llleg_geom" type="capsule" fromto="0 0 0 0 0 -0.26" size="0.06" rgba="0.8 0.6 0.4 1"/>

            <!-- Left Foot -->
            <body name="left_foot" pos="0 0 -0.26">
              <joint name="left_ankle" type="hinge" axis="0 1 0" range="-0.7 0.5" damping="1"/>
              <geom name="lfoot_geom" type="capsule" fromto="-0.04 0 0 0.14 0 -0.04" size="0.05" rgba="0.8 0.6 0.4 1"/>
            </body>
          </body>
        </body>

        <!-- Right Upper Leg -->
        <body name="right_upper_leg" pos="-0.1 0 -0.1">
          <joint name="right_hip" type="ball" damping="3.0"/>
          <geom name="ruleg_geom" type="capsule" fromto="0 0 0 0 0 -0.28" size="0.07" rgba="0.8 0.6 0.4 1"/>

          <!-- Right Lower Leg -->
          <body name="right_lower_leg" pos="0 0 -0.28">
            <joint name="right_knee" type="hinge" axis="0 1 0" range="-1.8 0.05" damping="1.5"/>
            <geom name="rlleg_geom" type="capsule" fromto="0 0 0 0 0 -0.26" size="0.06" rgba="0.8 0.6 0.4 1"/>

            <!-- Right Foot -->
            <body name="right_foot" pos="0 0 -0.26">
              <joint name="right_ankle" type="hinge" axis="0 1 0" range="-0.7 0.5" damping="1"/>
              <geom name="rfoot_geom" type="capsule" fromto="-0.04 0 0 0.14 0 -0.04" size="0.05" rgba="0.8 0.6 0.4 1"/>
            </body>
          </body>
        </body>

      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Leg actuators for basic standing/motion -->
    <motor name="left_hip_x"    joint="left_hip"      gear="80"/>
    <motor name="right_hip_x"   joint="right_hip"     gear="80"/>
    <motor name="left_knee"     joint="left_knee"     gear="60"/>
    <motor name="right_knee"    joint="right_knee"    gear="60"/>
    <motor name="left_ankle"    joint="left_ankle"    gear="40"/>
    <motor name="right_ankle"   joint="right_ankle"   gear="40"/>
  </actuator>

</mujoco>
